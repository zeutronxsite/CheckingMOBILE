-- Fungsi Mengambil Avatar dengan Failsafe (Cadangan)
local function getAvatarUrl(userId)
    -- Cara 1: API Thumbnail (Paling Bagus)
    local url1 = string.format("https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds=%d&size=150x150&format=Png&isCircular=false", userId)
    
    -- Cara 2: Link Langsung (Cadangan jika API error)
    local url2 = string.format("https://www.roblox.com/headshot-thumbnail/image?userId=%d&width=150&height=150&format=png", userId)

    local success, response = pcall(function()
        return game:HttpGet(url1)
    end)
    
    if success then
        local safe, data = pcall(function() 
            return game:GetService("HttpService"):JSONDecode(response) 
        end)
        
        if safe and data and data.data and #data.data > 0 then
            return data.data[1].imageUrl
        end
    end
    
    -- Jika Cara 1 gagal, kembalikan link Cara 2 (Langsung)
    return url2
end

