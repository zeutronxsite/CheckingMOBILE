local function createInstance(className, properties)
    local instance = Instance.new(className)
    for prop, value in pairs(properties) do
        -- Perbaikan: Gunakan pcall untuk mengecek apakah properti valid
        local success = pcall(function()
            instance[prop] = value
        end)
        if not success then
            warn("[ZETHUB] Invalid property ignored: " .. tostring(prop))
        end
    end
    return instance
end

local function tweenObject(object, info, properties)
    local tween = TweenService:Create(object, info, properties)
    tween:Play()
    return tween
end

local function getTimestamp()
    local time = os.date("*t")
    return string.format("%02d:%02d:%02d", time.hour, time.min, time.sec)
end

local function glitchText(textLabel, finalText, duration)
    local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*"
    local iterations = 8
    for i = 1, iterations do
        local glitched = ""
        for j = 1, #finalText do
            if math.random() > 0.5 then
                glitched = glitched .. string.sub(chars, math.random(1, #chars), math.random(1, #chars))
            else
                glitched = glitched .. string.sub(finalText, j, j)
            end
        end
        textLabel.Text = glitched
        task.wait(duration / iterations)
    end
    textLabel.Text = finalText
end

