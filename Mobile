local function getAvatarUrl(userId)
    -- Menggunakan API thumbnail Roblox untuk mendapatkan gambar kepala (Bust)
    local url = string.format("https://thumbnails.roblox.com/v1/users/avatar-bust?userIds=%d&size=150x150&format=Png&isCircular=false", userId)
    local success, result = pcall(function()
        return game:HttpGet(url)
    end)
    
    if success then
        local data = HttpService:JSONDecode(result)
        if data and data.data and #data.data > 0 then
            return data.data[1].imageUrl
        end
    end
    return nil -- Fallback ke inisial jika gagal
end

