-- ==========================================================================================================

local function updateProgress(percent, taskName, subTaskName)
    tweenObject(progressFill, TweenInfo.new(0.5, Enum.EasingStyle.Quart), {Size = UDim2.new(percent / 100, 0, 1, 0)})
    progressText.Text = math.floor(percent) .. "%"
    
    if taskName then
        glitchText(currentTaskLabel, taskName, 0.3)
    end
    if subTaskName then
        subTaskLabel.Text = subTaskName
    end
end

local function executeStage(stageName, url, progressStart, progressEnd)
    local statusIcon = addLog("Injecting: " .. stageName, "warning")
    updateProgress(progressStart, "INJECTING MODULE", stageName)
    task.wait(1.5)
    
    -- Safe Load Logic
    local success, err = pcall(function()
        local source = game:HttpGet(url)
        if source and #source > 10 then -- Cek apakah script tidak kosong
            loadstring(source)()
        else
            error("Script source empty or invalid")
        end
    end)
    
    if success then
        markLogSuccess(statusIcon)
        addLog("SUCCESS: " .. stageName .. " loaded", "success")
        updateProgress(progressEnd, "MODULE VERIFIED", "Checksum validation passed")
        task.wait(1)
    else
        statusIcon.Text = "X"
        statusIcon.TextColor3 = Colors.Danger
        addLog("FAILED: " .. stageName .. " (" .. tostring(err) .. ")", "error")
        updateProgress(progressEnd, "MODULE FAILED", "Bypassing error...")
        task.wait(1)
    end
end

